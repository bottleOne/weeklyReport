{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-conventions.sh",
            "timeout": 10,
            "statusMessage": "Checking project conventions..."
          }
        ]
      }
    ]
  }
}

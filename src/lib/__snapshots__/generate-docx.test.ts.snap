// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateDocxBuffer > matches structural snapshot for employee mode 1`] = `"<w:document <w:body <w:p <w:r <w:rPr <w:b <w:bCs <w:sz <w:szCs <w:u </w:rPr <w:t </w:t </w:r </w:p <w:tbl <w:tblPr <w:tblW <w:tblInd <w:tblBorders <w:top <w:left <w:bottom <w:right <w:insideH <w:insideV </w:tblBorders </w:tblPr <w:tblGrid <w:gridCol <w:gridCol <w:gridCol <w:gridCol </w:tblGrid <w:tr <w:trPr <w:trHeight </w:trPr <w:tc <w:tcPr <w:tcW <w:tcBorders <w:top <w:left <w:bottom <w:right </w:tcBorders <w:tcMar <w:top <w:left <w:bottom <w:right </w:tcMar <w:vAlign </w:tcPr <w:p <w:pPr <w:spacing <w:jc </w:pPr <w:r <w:rPr <w:b <w:bCs </w:rPr <w:t </w:t </w:r </w:p </w:tc <w:tc <w:tcPr <w:tcW <w:tcBorders <w:top <w:left <w:bottom <w:right </w:tcBorders <w:tcMar <w:top <w:left <w:bottom <w:right </w:tcMar <w:vAlign </w:tcPr <w:p <w:pPr <w:spacing <w:jc </w:pPr <w:r <w:t </w:t </w:r </w:p </w:tc <w:tc <w:tcPr"`;

exports[`generateDocxBuffer > matches structural snapshot for leader mode 1`] = `"<w:document <w:body <w:p <w:r <w:rPr <w:b <w:bCs <w:sz <w:szCs <w:u </w:rPr <w:t </w:t </w:r </w:p <w:tbl <w:tblPr <w:tblW <w:tblInd <w:tblBorders <w:top <w:left <w:bottom <w:right <w:insideH <w:insideV </w:tblBorders </w:tblPr <w:tblGrid <w:gridCol <w:gridCol <w:gridCol <w:gridCol </w:tblGrid <w:tr <w:trPr <w:trHeight </w:trPr <w:tc <w:tcPr <w:tcW <w:tcBorders <w:top <w:left <w:bottom <w:right </w:tcBorders <w:tcMar <w:top <w:left <w:bottom <w:right </w:tcMar <w:vAlign </w:tcPr <w:p <w:pPr <w:spacing <w:jc </w:pPr <w:r <w:rPr <w:b <w:bCs </w:rPr <w:t </w:t </w:r </w:p </w:tc <w:tc <w:tcPr <w:tcW <w:tcBorders <w:top <w:left <w:bottom <w:right </w:tcBorders <w:tcMar <w:top <w:left <w:bottom <w:right </w:tcMar <w:vAlign </w:tcPr <w:p <w:pPr <w:spacing <w:jc </w:pPr <w:r <w:t </w:t </w:r </w:p </w:tc <w:tc <w:tcPr"`;
